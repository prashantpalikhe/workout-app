# Server
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://workout:workout_dev@localhost:5432/workout_app

# JWT
JWT_SECRET=dev-secret-change-me-at-least-32-chars-long
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-32-chars

# OAuth (Google)
GOOGLE_CLIENT_ID=

# OAuth (Apple)
APPLE_CLIENT_ID=

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxx
MAIL_FROM=onboarding@resend.dev
FRONTEND_URL=http://localhost:3000

# Cloudinary (optional — avatar uploads disabled without these)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Sentry
SENTRY_DSN=

# API proxy target (server-side only — Nitro forwards /api/* to this URL)
NUXT_API_PROXY_URL=http://localhost:3001/api
